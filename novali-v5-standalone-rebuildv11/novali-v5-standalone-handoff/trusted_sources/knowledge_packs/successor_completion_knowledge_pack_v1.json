{
  "completion_rule": "all_required_deliverables_present_inside_active_workspace",
  "description": "Conservative bounded rubric for deciding whether an advanced mutable-shell successor package is complete enough inside the active workspace.",
  "deliverables": [
    {
      "deliverable_id": "planning_bundle",
      "evidence_relative_paths": [
        "plans/bounded_work_cycle_plan.md",
        "docs/mutable_shell_successor_design_note.md",
        "artifacts/bounded_work_file_plan.json",
        "artifacts/bounded_work_summary_latest.json"
      ],
      "required": true,
      "title": "Initial planning bundle"
    },
    {
      "deliverable_id": "implementation_bundle",
      "evidence_relative_paths": [
        "src/successor_shell/__init__.py",
        "src/successor_shell/workspace_contract.py",
        "tests/test_workspace_contract.py",
        "docs/successor_shell_iteration_notes.md",
        "artifacts/implementation_bundle_summary_latest.json"
      ],
      "required": true,
      "title": "First implementation bundle"
    },
    {
      "deliverable_id": "continuation_gap_analysis",
      "evidence_relative_paths": [
        "plans/successor_continuation_gap_analysis.md",
        "artifacts/trusted_planning_evidence_latest.json",
        "artifacts/missing_deliverables_latest.json",
        "artifacts/next_step_derivation_latest.json",
        "artifacts/completion_evaluation_latest.json"
      ],
      "required": true,
      "title": "Continuation gap analysis bundle"
    },
    {
      "deliverable_id": "successor_readiness_bundle",
      "evidence_relative_paths": [
        "src/successor_shell/successor_manifest.py",
        "tests/test_successor_manifest.py",
        "docs/successor_package_readiness_note.md",
        "artifacts/successor_readiness_evaluation_latest.json",
        "artifacts/successor_delivery_manifest_latest.json"
      ],
      "required": true,
      "title": "Successor readiness bundle"
    }
  ],
  "pack_id": "bounded_successor_completion_v1",
  "partial_completion_states": [
    {
      "condition": "planning_bundle_present_and_implementation_missing",
      "state_id": "planning_bundle_only"
    },
    {
      "condition": "implementation_bundle_present_and_readiness_bundle_missing",
      "state_id": "first_implementation_bundle_only"
    },
    {
      "condition": "continuation_gap_analysis_present_and_readiness_bundle_missing",
      "state_id": "ready_for_readiness_bundle"
    }
  ],
  "schema_name": "NovaliSuccessorCompletionKnowledgePack",
  "schema_version": "novali_successor_completion_knowledge_pack_v1"
}
